---
interface Estudio {
  titulo: string;
  institucion: string;
  periodo: string;
  descripcion: string;
  tipo: "universitario" | "tecnico" | "certificado" | "secundaria";
}

const estudios: Estudio[] = [
  {
    titulo: "Ingeniería de Sistemas",
    institucion: "Universidad —Unilasallista",
    periodo: "2022 — Presente",
    descripcion: "Carrera enfocada en el diseño, desarrollo y gestión de sistemas de información. Cursando materias como desarrollo web.",
    tipo: "universitario",
  },
  {
    titulo: "Certificado en Desarrollo Web",
    institucion: "Plataforma Online",
    periodo: "2025 - 2026",
    descripcion: "Certificación en HTML, CSS, JavaScript, Astro, tailwindcss. Completado con proyecto final de aplicación web completa.",
    tipo: "certificado",
  },
];

const iconos: Record<Estudio["tipo"], string> = {
  universitario: "🎓",
  tecnico: "🛠️",
  certificado: "📜",
  secundaria: "🏫",
};
---

<section id="estudios" class="py-24 px-6 relative">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="section-fade mb-16">
      <p class="text-xs font-mono font-medium tracking-[0.3em] text-[#c8a96e] uppercase mb-3">
        02. Educación
      </p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white tracking-tight accent-line inline-block">
        Estudios Realizados
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-[1px] bg-gradient-to-b from-[#c8a96e44] via-[#c8a96e22] to-transparent md:-translate-x-1/2 hidden md:block"></div>

      <div class="space-y-8 md:space-y-0">
        {estudios.map((estudio, i) => (
          <div class={`section-fade md:grid md:grid-cols-2 md:gap-12 md:mb-12 relative ${i % 2 === 0 ? '' : 'md:direction-rtl'}`}>
            {/* Left side (even) / right side (odd) */}
            <div class={`${i % 2 === 0 ? 'md:text-right md:pr-12' : 'md:col-start-2 md:pl-12'}`}>
              <div class={`glass glass-hover rounded-2xl p-6 relative group cursor-default`}>
                <!-- Type badge -->
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xl">{iconos[estudio.tipo]}</span>
                  <span class="tag capitalize">{estudio.tipo}</span>
                </div>

                <h3 class="text-lg sm:text-xl font-bold text-white mb-1 group-hover:text-[#c8a96e] transition-colors duration-200">
                  {estudio.titulo}
                </h3>
                <p class="text-[#c8a96e] text-sm font-mono font-medium mb-1">
                  {estudio.institucion}
                </p>
                <p class="text-[#606060] text-xs font-mono mb-3">
                  {estudio.periodo}
                </p>
                <p class="text-[#808080] text-sm leading-relaxed">
                  {estudio.descripcion}
                </p>
              </div>
            </div>

            {/* Dot on timeline */}
            <div class={`hidden md:flex absolute left-1/2 top-6 -translate-x-1/2 w-3 h-3 rounded-full border-2 border-[#c8a96e] bg-[#0a0a0a] z-10`}></div>

            {/* Empty column for odd items */}
            {i % 2 !== 0 && <div class="md:col-start-1 md:row-start-1"></div>}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
