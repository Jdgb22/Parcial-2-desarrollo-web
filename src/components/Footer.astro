---
---

<footer class="py-12 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Left: Brand -->
      <div class="flex items-center gap-3">
        <span class="w-8 h-8 rounded-full bg-gradient-to-br from-[#c8a96e] to-[#a8894e] flex items-center justify-center text-black font-bold text-xs font-mono">
          JD
        </span>
        <div>
          <p class="text-sm font-semibold text-white">Juan David García</p>
          <p class="text-xs text-[#404040] font-mono">Desarrollador de Software</p>
        </div>
      </div>

      <!-- Center: Links -->
      <div class="flex items-center gap-8">
        <a href="#hero" class="text-xs text-[#505050] hover:text-[#c8a96e] transition-colors no-underline font-mono">inicio</a>
        <a href="#proyectos" class="text-xs text-[#505050] hover:text-[#c8a96e] transition-colors no-underline font-mono">proyectos</a>
        <a href="#skills" class="text-xs text-[#505050] hover:text-[#c8a96e] transition-colors no-underline font-mono">skills</a>
      </div>

      <!-- Right: Social links -->
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-8 h-8 rounded-full glass border border-white/8 flex items-center justify-center text-[#505050] hover:text-[#c8a96e] hover:border-[#c8a96e44] transition-all duration-200 no-underline text-xs font-mono"
          title="GitHub"
        >
          GH
        </a>
        <a
          href="https://linkedin.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-8 h-8 rounded-full glass border border-white/8 flex items-center justify-center text-[#505050] hover:text-[#c8a96e] hover:border-[#c8a96e44] transition-all duration-200 no-underline text-xs font-mono"
          title="LinkedIn"
        >
          in
        </a>
        <a
          href="mailto:juan@example.com"
          class="w-8 h-8 rounded-full glass border border-white/8 flex items-center justify-center text-[#505050] hover:text-[#c8a96e] hover:border-[#c8a96e44] transition-all duration-200 no-underline text-xs font-mono"
          title="Email"
        >
          @
        </a>
      </div>
    </div>

    <!-- Bottom line -->
    <div class="mt-8 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-[#303030] font-mono">
        © {new Date().getFullYear()} Juan David García López. Todos los derechos reservados.
      </p>
      <p class="text-xs text-[#303030] font-mono flex items-center gap-1">
        Hecho con <span class="text-[#c8a96e]">♦</span> usando Astro + Tailwind CSS
      </p>
    </div>
  </div>
</footer>
