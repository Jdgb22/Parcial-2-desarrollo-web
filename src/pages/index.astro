---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Estudios from "../components/Estudios.astro";
import Proyectos from "../components/Proyectos.astro";
import Skills from "../components/Skills.astro";
import Intereses from "../components/Intereses.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Juan David Giraldo Benjumea — Portafolio"
  description="Portafolio profesional de Juan David Giraldo Benjumea. Desarrollador de Software estudiante de Ingeniería de Informática."
>
  <Navbar />
  <main>
    <Hero />

    <!-- Divider -->
    <div class="max-w-6xl mx-auto px-6">
      <div
        class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>
    </div>

    <Estudios />

    <div class="max-w-6xl mx-auto px-6">
      <div
        class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>
    </div>

    <Proyectos />

    <div class="max-w-6xl mx-auto px-6">
      <div
        class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>
    </div>

    <Skills />

    <Intereses />
  </main>

  <Footer />
</Layout>
